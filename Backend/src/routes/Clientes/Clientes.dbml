Table clientes {
  id_cliente int [pk, increment]

  tipo_cliente varchar [not null]
  segmento varchar

  nome_razao varchar [not null]
  nome_fantasia varchar
  cpf_cnpj varchar [not null]

  inscricao_estadual varchar
  inscricao_municipal varchar

  status_cliente varchar
  aceita_marketing boolean

  ultima_compra datetime

  created_at datetime
  updated_at datetime
}

Table cliente_enderecos {
  id_endereco int [pk, increment]

  id_cliente int [not null]

  tipo varchar // COBRANCA, ENTREGA, PRINCIPAL etc

  logradouro varchar
  numero varchar
  complemento varchar
  bairro varchar
  cidade varchar
  estado varchar
  cep varchar
  pais varchar

  referencia varchar

  created_at datetime
  updated_at datetime
}

Ref: cliente_enderecos.id_cliente > clientes.id_cliente


Table cliente_contatos {
  id int [pk, increment]

  id_cliente int [not null]

  nome varchar
  telefone varchar

  tipo varchar // COMERCIAL, FINANCEIRO, etc

  principal boolean
  whatsapp boolean

  referencia varchar

  created_at datetime
  updated_at datetime
}

Ref: cliente_contatos.id_cliente > clientes.id_cliente

Table cliente_emails {
  id int [pk, increment]

  id_cliente int [not null]

  email varchar [not null]

  tipo varchar

  principal boolean
  verificado boolean

  created_at datetime
  updated_at datetime
}

Ref: cliente_emails.id_cliente > clientes.id_cliente

Table cliente_credito {
  id int [pk, increment]

  id_cliente int [not null]

  limite_credito decimal
  dia_vencimento int
  status_credito varchar

  score_credito int

  created_at datetime
  updated_at datetime
}

Ref: cliente_credito.id_cliente > clientes.id_cliente

Table cliente_financeiro {
  id int [pk, increment]

  id_cliente int [not null]

  saldo_devedor_atual decimal

  total_aberto decimal
  total_pago decimal
  total_atrasado decimal

  created_at datetime
  updated_at datetime
}

Ref: cliente_financeiro.id_cliente > clientes.id_cliente

Table cliente_crm {
  id int [pk, increment]

  id_cliente int [not null]

  classificacao varchar
  potencial varchar
  score_comercial int

  segmento varchar

  created_at datetime
  updated_at datetime
}

Ref: cliente_crm.id_cliente > clientes.id_cliente

Table cliente_documentos {
  id int [pk, increment]

  id_cliente int [not null]

  tipo varchar // RG, CONTRATO, COMPROVANTE, OUTRO
  nome varchar

  url varchar // arquivo (S3, disco, etc)

  observacao varchar

  created_at datetime
  updated_at datetime
}

Ref: cliente_documentos.id_cliente > clientes.id_cliente

Table cliente_atividades {
  id int [pk, increment]

  id_cliente int [not null]

  tipo varchar // LIGACAO, VENDA, COBRANCA, VISITA, OBSERVACAO
  titulo varchar
  descricao text

  prioridade varchar // BAIXA, MEDIA, ALTA, URGENTE

  data datetime

  created_by int

  created_at datetime
}

Ref: cliente_atividades.id_cliente > clientes.id_cliente

Table tags {
  id int [pk, increment]

  nome varchar [not null]
  cor varchar

  created_at datetime
}

Table cliente_tags {
  id_cliente int
  id_tag int

  created_at datetime

  indexes {
    (id_cliente, id_tag) [pk]
  }
}

Ref: cliente_tags.id_cliente > clientes.id_cliente
Ref: cliente_tags.id_tag > tags.id


Table cliente_precos_especiais {
  id int [pk, increment]

  id_cliente int [not null]
  id_produto int [not null]

  tipo_desconto varchar // VALOR_FIXO | PERCENTUAL

  preco_final decimal // ex: 10.00
  percentual_desconto decimal

  motivo varchar // concorrência, fidelidade, volume

  ativo boolean

  data_inicio datetime
  data_fim datetime

  created_at datetime
}

Ref: cliente_precos_especiais.id_cliente > clientes.id_cliente

Table cliente_eventos {
  id int [pk, increment]

  id_cliente int [not null]

  tipo varchar
  // COMPRA, PAGAMENTO, ATRASO, LIGACAO, ORCAMENTO, DESCONTO, VISITA

  origem varchar
  // vendas, crm, financeiro, sistema, manual

  referencia_id int // id da venda, conta, etc

  valor decimal

  payload json // FLEXÍVEL (muito importante)

  data datetime

  created_at datetime
}

Table cliente_metricas_snapshot {
  id int [pk, increment]

  id_cliente int

  data_ref datetime

  score_credito int
  score_comercial int

  limite_credito decimal
  saldo_devedor decimal

  total_compras_30d decimal
  total_compras_90d decimal

  compras_count_30d int

  created_at datetime
}

Table cliente_perfil_agregado {
  id int [pk, increment]

  id_cliente int

  ticket_medio decimal

  frequencia_compra_dias int

  dias_desde_ultima_compra int

  total_gasto decimal

  total_compras int

  categoria_frequente varchar

  sensibilidade_preco varchar
  // BAIXA | MEDIA | ALTA

  risco_inadimplencia decimal

  probabilidade_churn decimal

  valor_lifetime_estimado decimal

  updated_at datetime
}


Sua estrutura está muito bem encaminhada e demonstra uma maturidade de sistema ERP/CRM profissional. A separação das tabelas de banco de dados (especialmente `cliente_eventos` e `cliente_perfil_agregado`) vai facilitar muito a escalabilidade e a performance.

Para que seu sistema fique "à prova de balas", notei alguns pontos que podem ser ajustados ou adicionados em ambos os lados (TypeScript e Banco de Dados):

---

### 1. No Banco de Dados (DBML)

**A. Soft Delete:**
Sua interface TS tem `deletado_em`, mas as tabelas do banco não possuem a coluna `deleted_at`.

* **Sugestão:** Adicione `deleted_at datetime` na tabela `clientes` e possivelmente em `cliente_contatos` e `emails`.

**B. Unicidade e Indexação:**

* A coluna `cpf_cnpj` na tabela `clientes` deve ser `unique`.
* A coluna `email` na tabela `cliente_emails` também deve ser `unique`.

**C. Relacionamento de Usuários (Auditoria):**
Suas interfaces TS mencionam `criado_por` e `atualizado_por` (IDs numéricos). No banco, as tabelas de auditoria só têm as datas.

* **Sugestão:** Adicione `created_by int` e `updated_by int` nas tabelas principais para manter o vínculo com a tabela de usuários do sistema.

**D. Tabela de Preços Especiais:**
Você tem `id_produto`, mas se o seu sistema crescer, você pode querer dar desconto para uma **Categoria** inteira ou uma **Marca**.

* **Sugestão:** Adicionar `id_categoria int [null]` e `id_marca int [null]` na tabela `cliente_precos_especiais`.

---

### 2. Nas Interfaces TypeScript

**A. Sincronia com o Banco (Campos Faltantes):**
Faltam alguns campos na interface `Cliente` que você criou no banco:

* `cliente_documentos`: Não há interface para isso no TS.
* `cliente_tags`: Você criou a tabela, mas a interface `ClienteCompleto` não tem um array de `tags`.

**B. Tipagem do Payload de Eventos:**
A tabela `cliente_eventos` tem um campo `payload json`. No TS, seria bom definir isso como um tipo flexível ou genérico para evitar o uso de `any`.

```typescript
export interface ClienteEvento extends Auditoria {
  id: number;
  tipo: string;
  payload: Record<string, unknown>; // Mais seguro que any
}

```

---

### 3. O que pode estar faltando (Regras de Negócio)

Aqui estão três pontos que costumam "aparecer" depois que o sistema entra em produção:

1. **Hierarquia de Clientes (Matriz e Filial):**
* Se um cliente for uma grande rede, ele pode ter várias filiais.
* **Sugestão:** Adicionar `id_cliente_pai int` na tabela `clientes` para criar essa árvore.


2. **Configurações de Faturamento:**
* Faltam campos como: "Exige Nota Fiscal Eletrônica?", "Consumidor Final ou Revenda?" (importante para cálculo de ST/IPI), "Isento de ICMS?".
* **Sugestão:** Criar uma interface/tabela `ClienteFiscal` ou expandir a `Cliente`.


3. **Gestão de Limite de Crédito Temporário:**
* Muitas vezes você quer aumentar o limite de um cliente apenas para uma venda específica ou por um mês. Sua estrutura atual é estática.
* **Sugestão:** Um campo `limite_temporario_validade` na tabela de crédito.



---

### Resumo da Estrutura Recomendada (Visual)

### Sugestão de Organização de Arquivos

Como o código TS ficou grande, siga o conselho do comentário 17 que você mesmo postou:

1. `base.types.ts` (Auditoria, Endereco, Enums comuns)
2. `cliente.types.ts` (A interface `Cliente` core)
3. `financeiro.types.ts` (Contas, Crédito, Preços)
4. `analytics.types.ts` (Insights, Métricas, Perfil)

**Conclusão:** O design está excelente. Se você adicionar o **Soft Delete** no banco e a **Hierarquia (Matriz/Filial)**, terá um modelo capaz de atender desde pequenas empresas até operações complexas de atacado.

Você pretende implementar a lógica de cálculo do `cliente_perfil_agregado` via *Triggers* no banco ou via *Worker* no backend?