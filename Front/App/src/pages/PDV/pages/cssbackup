}

@keyframes pulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

/* MODAL DO GERENTE (Deve continuar centralizado na tela toda) */
.manager-lock-overlay {
  position: fixed;
  top: 0; left: 0; width: 100vw; height: 100vh;
  background: rgba(15, 23, 42, 0.8);
  backdrop-filter: blur(4px);
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 9999;
}

.manager-lock-card {
  background: white;
  padding: 2.5rem;
  border-radius: 16px;
  text-align: center;
  width: 350px;
}

.manager-lock-card .icon { font-size: 3rem; display: block; margin-bottom: 1rem; }

.manager-lock-card input {
  width: 100%;
  padding: 1rem;
  margin: 1.5rem 0 1rem 0;
  font-size: 1.2rem;
  text-align: center;
  border: 2px solid #cbd5e1;
  border-radius: 8px;
}

.manager-lock-card button {
  width: 100%;
  padding: 1rem;
  background: #1e293b;
  color: white;
  border: none;
  border-radius: 8px;
  font-weight: bold;
  cursor: pointer;
}



.checkout-container {
  flex: 1; 
  display: flex;
  flex-direction: column; /* Organiza os itens um abaixo do outro */
height: 100%; /* Ele vai herdar os 100% do pai que é fixo */
  overflow: hidden;      /* IMPEDE que o container inteiro role; a rolagem será só no body */
  padding-left: 10px;
}

.checkout-header {
  flex: 0 0 auto; /* Não cresce, não encolhe, mantém o tamanho do conteúdo */
  padding: 15px;
  background: #fff;
  border-bottom: 1px solid #ddd;
}

.checkout-body {
  flex: 1;        /* O SEGREDO: Ele estica para ocupar todo o espaço entre header e footer */
  overflow-y: auto; /* Se os produtos passarem da altura, a barra de rolagem aparece AQUI */
  padding: 0px 10px;
  background-color: #FFFFD5;
}

.checkout-footer {
  flex: 0 0 auto; /* Fica sempre "ancorado" no final do container */
  background: #ffffff;

}


.payment-methods-header{
  display: grid;
  grid-template-columns: 1fr 1fr;
}


/* SEÇÃO SUPERIOR (Pagamentos): Esta parte cresce e tem scroll */
.payment-methods {
  flex: 1; /* Faz esta parte ocupar o máximo de espaço possível */
  overflow-y: auto; /* Se houver muitos métodos de pagamento, o scroll aparece aqui */
}



/* Gatilho (Botão que abre) */
.accordion-trigger {
    width: 100%;
    display: flex;
    justify-content: space-between; 
    align-items: center;
    padding: 5px;
    background: #efefef;
    border: 1px solid #ccc;
    border-radius: 6px 6px 0 0;
    cursor: pointer;
    font-size: 0.85rem;
    font-weight: 600;
    color: #475569;
    transition: background 0.2s;
}

.accordion-trigger:hover {
    background: #ddd;
}

/* Container da Sanfona */
.coupon-and-discount {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease-in-out, opacity 0.2s ease-in-out;
    opacity: 0;
    background: #fff;
    /* Importante: remover paddings/borders daqui para não quebrar a animação */
}

.coupon-and-discount.open {
    max-height: 500px; /* Valor alto o suficiente para o conteúdo */
    opacity: 1;
    margin-bottom: 1rem;
}

/* Wrapper interno para dar espaçamento sem quebrar a animação de altura */
.accordion-content {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12px;
  background-color: #EFEFEF;
    border: 1px solid #ddd;
}

