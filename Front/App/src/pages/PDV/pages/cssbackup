/* Histórico de pagamentos adicionados */
.payment-history {
  list-style: none;
  padding: 0;
  margin: 1rem 0;
}

.payment-history li {
  display: flex;
  justify-content: space-between;
  padding: 8px;
  background: #ddd;
  border-radius: 6px;
  margin-bottom: 5px;
  font-size: 0.9rem;
}

.totals-panel {
  margin-top: auto; /* Empurra o painel para o final do container */
  padding: 1rem 0 ;
  
  /* Garante que o painel não encolha */
  flex-shrink: 0; 
  
  /* Opcional: fixar mesmo com scroll */
  position: sticky;
  bottom: 0;
  z-index: 10;
}


.cupons-grid {
  display: grid;
 grid-template-columns: repeat(3, 1fr);
  gap: 8px;
}

.cupons-grid button {
  color: #0f172a;
  padding: 0.8rem 0rem ;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  background: white;
  cursor: pointer;
  font-weight: 700;
  font-size: xx-small;
}


.method-grid {
  display: grid;
 grid-template-columns: repeat(6, 1fr);
  gap: 8px;
}



/* O primeiro botão (Dinheiro) ocupa as 3 colunas do topo */
.method-grid button:nth-child(1) {
    grid-column: 1 / 4; /* ou span 3 */
}

/* O quinto botão (Crediário) ocupa as 3 colunas da base */
.method-grid button:nth-child(2) {
    grid-column: 4 / 7; /* ou span 3 */
}

/* O quinto botão (Crediário) ocupa as 3 colunas da base */
.method-grid button:nth-child(3) {
    grid-column: 1 / 3; /* ou span 3 */
}

.method-grid button:nth-child(4) {
    grid-column: 3 / 5; /* ou span 3 */
}

.method-grid button:nth-child(5) {
    grid-column: 5 / 7; /* ou span 3 */
}

.method-grid button {
  color:#000;
  padding: 0.8rem 0rem ;
  border: 2px solid #e2e8f0;
  border-radius: 8px;
  background: white;
  cursor: pointer;
  font-weight: 500;
  font-size: medium;
}

.method-grid button.active {
  border-color: #2563eb;
  background: #eff6ff;
  color: #2563eb;
}



